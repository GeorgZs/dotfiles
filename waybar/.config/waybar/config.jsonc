{
  "layer": "top",
  "position": "top",
  "spacing": 4,
  "margin-top": 5,
  "margin-bottom": 0,
  "margin-left": 5,
  "margin-right": 5,

  "modules-left": [
    "custom/icon",
    "hyprland/workspaces",
    "hyprland/window",
  ],

  "modules-center": [
    "clock",
    "custom/weather",
  ],

  "modules-right": [
    "backlight",
    "wireplumber",
    "network",
    "custom/battery",
    "tray",
    "idle_inhibitor",
    "custom/power",
    "custom/notifications",
  ],

  "custom/icon": {
    "exec": "~/.dots/config/waybar/os_icon.sh",
    "interval": "once",
    "format": "{}",
    "on-click": "rofi -show drun",
    "tooltip": false 
  },

  "clock": {
		"format": "<b>َ°¥”  {:%H:%M   َ°ƒ­  %d.%m}</b> ",
		//"format": "{:%a}",
		"tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
                    "mode"          : "month",
                    "format": {
                              "months":     "<span color='#cdd6f4'><b>{}</b></span>",
                              "days":       "<span color='#cdd6f4'><b>{}</b></span>",
                              "weeks":      "<span color='#cdd6f4'><b>W{}</b></span>",
                              "weekdays":   "<span color='#cdd6f4'><b>{}</b></span>",
                              "today":      "<span color='#f38ba8'><b>{}</b></span>"
                              }
                    },
    },

  "hyprland/window": {
    "format": "ï‚©  {}",
    "rewrite": {
      "(.*) â€” Mozilla Firefox": "َ°ˆ¹  Firefox",
      "(.*) - nvim": "îڑ® Neovim"
    }
  },

  "hyprland/workspaces" : {
      "on-click": "activate",
      "active-only": false,
      "all-outputs": true,
      "format": "{icon}",
      "format-icons": {
	      "urgent": "ïپھ",
	      "active": "ï†’",
        "default": "ï„Œ"
      },
      "persistent-workspaces": {
          "*": 4
      }       
  },
  
  "backlight": {
    "format": "{icon} <b>{percent}%</b>",
    "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
    "tooltip": false,
   },

  "wireplumber": {
    "format": "{icon} <b>{volume}%</b>",
    "format-bluetooth": "{icon} ïٹ” <b>{volume}%</b>",
    "format-bluetooth-muted": "َ°‌ں ïٹ”",
    "format-muted": " َ°‌ں ",
    "format-icons": {
      "headset": "ï€¥",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"],
    },
    "tooltip": false,
    "on-click": "pavucontrol",
  },

  "network": {
    "interval": 30,
    "format-wifi": "َ°¤¨ {essid}",
    "format-ethernet": "َ°ˆ€ Wired",
    "fomat-disconnected": "َ±ڑµ Disconnected",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname} ïƒپ",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "nm-connection-editor"
  },

  "custom/battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 4,
    "max-length": 25,
    "tooltip": false,
    "format": "{icon} {percentage}% {}",
    "format-icons": ["َ°‚ژ", "َ°پ»", "َ°پ½", "َ°پ؟", "َ°‚پ", "َ°پ¹"],
    "return-type": "json",
    "exec": "$HOME/.dots/config/waybar/wbm_battery1"
  },

  "tray": {
    "icon-size": 16,
    "spacing": 15,
  },

   "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "َ°ˆˆâ€¯",
        "deactivated": "َ°ˆ‰â€¯"
    },
  },

  "custom/power": {
    "format": "َ°گ¥",
    "on-click": "wlogout",
    "tooltip": false,
  },
  "custom/notifications": {
      "format": "ï‚¢",
      "on-click": "swaync-client -t",
      "tooltip": true,
      "tooltip-format": "Notifications"
  },
  "custom/weather": {
      "format": "{}",
      "tooltip": true,
      "interval": 1000,
      "exec": "$HOME/.dots/config/waybar/wttr.py",
      "return-type": "json",
  }
}

